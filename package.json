{
  "name": "@cuongph.dev/backlog-mcp",
  "version": "0.1.3",
  "description": "MCP server for Backlog (Nulab) — read issues, comments, attachments via API Key",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cuongph-dev-work/backlog-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/cuongph-dev-work/backlog-mcp/issues"
  },
  "homepage": "https://github.com/cuongph-dev-work/backlog-mcp#readme",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "backlog-mcp": "dist/server.js"
  },
  "files": [
    "dist/backlog",
    "dist/tools",
    "dist/types",
    "dist/config.js",
    "dist/config.d.ts",
    "dist/errors.js",
    "dist/errors.d.ts",
    "dist/server.js",
    "dist/server.d.ts",
    "dist/types.js",
    "dist/types.d.ts",
    "dist/utils.js",
    "dist/utils.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --noEmit false --outDir dist",
    "prepare": "npm run build && chmod +x dist/server.js",
    "dev": "tsx src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm test",
    "snyk:test": "snyk test",
    "snyk:monitor": "snyk monitor"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "axios": "^1.7.7",
    "dayjs": "^1.11.20",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}